VITE_SUPABASE_URL=ton_url
VITE_SUPABASE_ANON_KEY=ta_cle_anon

# Cloud Name et API Key Cloudinary : pas des secrets (nécessairement exposés
# côté client pour l'upload widget en mode "unsigned"), d'où le préfixe
# VITE_ sans risque ici.
VITE_CLOUDINARY_CLOUD_NAME=ton_cloud_name
VITE_CLOUDINARY_API_KEY=ta_cle_api

# Préparation pour une future intégration CinetPay (paiement en ligne).
# Pas encore utilisées dans le code actuel.
VITE_CINETPAY_SITE_ID=
VITE_CINETPAY_API_KEY=

# GEMINI_API_KEY n'est PAS une variable client (pas de préfixe VITE_ —
# volontairement absent ici). C'est un secret de l'Edge Function
# supabase/functions/gemini-proxy. Ne JAMAIS la préfixer par VITE_ (sinon
# elle serait à nouveau embarquée dans le bundle du navigateur, visible par
# n'importe quel visiteur). À définir avec :
#   supabase secrets set GEMINI_API_KEY=ta_cle

# NOVU_API_KEY : même règle, secret de l'Edge Function
# supabase/functions/novu-proxy. À définir avec :
#   supabase secrets set NOVU_API_KEY=ta_cle

# CLOUDINARY_API_SECRET : jamais utilisée dans le code applicatif (upload
# non-signé côté client via preset "unsigned"). Utile uniquement pour des
# actions ponctuelles via l'API Admin Cloudinary (ex: créer/modifier un
# upload preset) — ne JAMAIS la préfixer par VITE_.
